---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'arc-enabled-kubernetes');
const { Content } = await entry.render();
const { title, description, heroEmoji, heroSubtitle, accentColor } = entry.data;
---

<BaseLayout title={title} description={description} currentPage="arc-enabled-kubernetes">
  <header class="page-hero">
    {heroEmoji && <span class="hero-emoji">{heroEmoji}</span>}
    <h1>{title}</h1>
    {heroSubtitle && <p class="subtitle">{heroSubtitle}</p>}
  </header>
  <div class="container mdx-content">
    <Content />
  </div>
</BaseLayout>
