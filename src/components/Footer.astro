---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <p>Azure Arc — The Complete Guide to Hybrid & Multicloud Management</p>
    <p class="footer-meta">Built with <a href="https://astro.build">Astro</a> · {year}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    margin-top: 4rem;
    text-align: center;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    color: var(--text-dim);
    font-size: 0.85rem;
  }
  .footer-meta { margin-top: 0.5rem; }
  .footer-meta a {
    color: var(--accent);
    text-decoration: none;
  }
</style>
